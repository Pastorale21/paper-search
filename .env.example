# Data source backend: "openalex" (default, free, no key) or "s2"
DATA_SOURCE=openalex

# OpenAlex polite-pool email (optional; faster, more reliable when set)
OPENALEX_MAILTO=

# Semantic Scholar Graph API key (only needed when DATA_SOURCE=s2)
S2_API_KEY=

# LLM API (OpenAI-compatible; DeepSeek default, switchable to OpenAI/Claude-compatible)
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
