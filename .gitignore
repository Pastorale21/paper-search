
# caches & runtime artifacts
# 重建产物默认忽略,只放行下面的基准缓存,保证 fresh clone 零成本可跑
data/cache/*
!data/cache/papers.json
!data/cache/embeddings.npy
!data/cache/faiss.index
!data/cache/ids.json
!data/cache/citation_graph.pkl
!data/cache/method_cards/
# sibling cache backups/archives — NOT covered by data/cache/* above
data/cache.bak*/
data/cache*.zip
# secrets
.env

# python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.pytest_cache/
.ruff_cache/

# os
.DS_Store

# pyvis writes these to cwd on some paths despite cdn_resources='in_line';
# belt-and-suspenders. ui/components/graph_view.py writes to tempfile, but if
# something regresses we don't want lib/ or tmp_graph.html to land in the repo.
lib/
tmp_graph.html
